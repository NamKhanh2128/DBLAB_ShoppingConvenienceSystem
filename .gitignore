# ────────────────────────────────────────────────────────────────────────
# DEPENDENCY DIRECTORIES
# ────────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
bower_components/

# ────────────────────────────────────────────────────────────────────────
# BUILD OUTPUTS
# ────────────────────────────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
out/
**/out/
.next/
.nuxt/
.cache/

# ────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & LOCAL SECRETS (Never commit sensitive configs)
# ────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*
.envrc

# ────────────────────────────────────────────────────────────────────────
# LOG FILES
# ────────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ────────────────────────────────────────────────────────────────────────
# IDE & EDITOR FILES
# ────────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.slnx
*.sqlite
*.db
*.swp
*.swo
.project
.classpath
.settings/

# ────────────────────────────────────────────────────────────────────────
# OPERATING SYSTEM FILES
# ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ────────────────────────────────────────────────────────────────────────
# PROJECT SPECIFIC TEMPORARY FILES
# ────────────────────────────────────────────────────────────────────────
# Ignore PDF lecture/lab documents at the root level
/*.pdf
